<launch>
  <arg name="namespace" default="hsrb" />
  <arg name="personal_name" default="" />

  <group>
    <node name="head_l_stereo_camera_frame_pub" pkg="tf2_ros" exec="static_transform_publisher"
          args="--frame-id $(var personal_name)/head_l_stereo_camera_link --child-frame-id $(var personal_name)/head_l_stereo_camera_frame" />
    <node name="head_r_stereo_camera_frame_pub" pkg="tf2_ros" exec="static_transform_publisher"
          args="--frame-id $(var personal_name)/head_r_stereo_camera_link --child-frame-id $(var personal_name)/head_r_stereo_camera_frame" />
    <node name="head_rgbd_sensor_rgb_frame_pub" pkg="tf2_ros" exec="static_transform_publisher"
          args="--frame-id $(var personal_name)/head_rgbd_sensor_link --child-frame-id $(var personal_name)/head_rgbd_sensor_rgb_frame" />
    <node name="head_rgbd_sensor_depth_frame_pub" pkg="tf2_ros" exec="static_transform_publisher"
          args="--frame-id $(var personal_name)/head_rgbd_sensor_link --child-frame-id $(var personal_name)/head_rgbd_sensor_depth_frame" />

  </group>
</launch>
